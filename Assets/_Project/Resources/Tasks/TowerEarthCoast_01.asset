  taskId: tower_ecocolumn_01
  title: "\"Real Coast\" Eco-Column Recovery"
  client: "Anonymous client (Mars relay)"
  description: "A sealed living eco-column is stored inside the derelict Earth Coast 01 pre-sale tower. Recover it. A broken seal voids acceptance; each drop deducts by completeness. The building has no power - the substation is on floor 1. Note: the original site supervisor is still on duty."
  locationName: "Earth Coast 01 - Derelict Pre-Sale Tower"
  sceneName: Tower_EarthCoast_01
  recommendedPlayersMin: 1
  recommendedPlayersMax: 4
  requiredOfficeLevel: 1
  minimumReputation: -100
