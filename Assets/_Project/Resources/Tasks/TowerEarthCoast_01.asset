  realSecondsPerGameHour: 60
  overtimeMoneyPenaltyPerGameHour: 30
  overtimeReputationPenaltyBlockGameHours: 2
  overtimeReputationPenaltyPerBlock: 1
  moneyReward: 300
  reputationReward: 5
  experienceReward: 80
  failureConsolationMoney: 20
  failureReputationPenalty: -2
  failureExperience: 0
  settlementNotesSuccess:
  - "Fingerprints found on the column's rim; sterilization arranged. Paid in full. Don't make a habit of it."
  - "Water seal intact. Transit time is not counted toward pay - that was your own scheduling."
  settlementNotesPartial:
  - "Coming back empty-handed is also a result. See the reverse for terms; the reverse is blank."
  - "Your office clocked out early. The cargo berth is billed regardless, and deducted from your pay."
  settlementNotesFailure:
  - "Personnel losses are your office's internal affair. Condolence money paid at the floor rate."
  - "The item is still on site. If your office resumes operations, you are welcome to bid again."
